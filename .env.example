# ════════════════════════════════════════════════════════════════
# LEGAL SUCCESS INDIA — Trademark Lead Portal — Environment Config
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════════

# ── Gemini AI (for screenshot OCR scanning) ──────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# ── JWT Secret (for login sessions) ─────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS"

# ── Firebase Firestore (pick ONE of the two methods below) ──────────────────────

# METHOD 1: Service Account JSON File (Recommended for local dev)
# Download from: Firebase Console → Settings → Service Accounts → Generate new private key
# Save the downloaded JSON as "firebase-service-account.json" in project root
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# METHOD 2: Individual Environment Variables (Recommended for deployment)
# Copy these values from the service account JSON file
# FIREBASE_PROJECT_ID="trademark-leads-xxxxx"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@trademark-leads-xxxxx.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── App URL (optional, for hosted deployments) ────────────────────
APP_URL="http://localhost:3000"
